---
import '../styles/global.css';
import MicroWidget from '../components/MicroWidget';
import RecordPlayer from '../components/RecordPlayer';
import LivingCats from '../components/LivingCats/LivingCats';
import Atmosphere from '../components/Atmosphere';
import CuriosityEvent from '../components/CuriosityEvent';
import ShiftAmbience from '../components/ShiftAmbience';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string | URL;
  image?: string;
  type?: 'website' | 'article';
  schema?: string;
  noindex?: boolean;
  mainClass?: string;
}

const { 
  title = "OkayImBored — The Internet's Strange Little Place for Bored People", 
  description = "Bored? Spend one minute with us. Explore weird facts, tiny experiments, random thoughts, and surprisingly comforting internet experiences.",
  canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://okayimbored.com'),
  image = '/social-card.jpg',
  type = 'website',
  schema,
  noindex = false,
  mainClass = "w-full max-w-2xl mx-auto px-4 pt-8 pb-24 sm:px-6 sm:py-12 flex-1 flex flex-col items-center justify-center"
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="ImBored" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<ClientRouter />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		{!noindex && <meta name="robots" content="index, follow" />}
		
		<!-- OpenGraph -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />
		<meta property="og:site_name" content="OkayImBored" />
		<meta property="og:locale" content="en_US" />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- JSON-LD Schema Injection -->
		{schema && <script type="application/ld+json" set:html={schema} />}
		
		<!-- Preload the standard font we are simulating -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Mono&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0a0a] text-white/90 font-sans min-h-[100dvh] flex flex-col overflow-x-hidden selection:bg-white/10 selection:text-white">
		<main class={mainClass}>
			<slot />
		</main>
		<RecordPlayer client:load transition:persist="record-player" />
		<MicroWidget client:idle />
		<LivingCats client:idle />
		<Atmosphere client:load transition:persist="atmosphere" />
		<CuriosityEvent client:load transition:persist="curiosity" />
		<ShiftAmbience client:idle transition:persist="shift-ambience" />

		<script>
			const updateSecretState = () => {
				const secretPaths = ['/quiet', '/window', '/attic', '/after-hours', '/basement', '/rooftop', '/wait', '/cats', '/radio', '/lost-and-found', '/polaroid', '/archive'];
				const path = window.location.pathname;
				const isSecret = secretPaths.some(p => path === p || path === p + '/') || document.title.toLowerCase().includes('404');
				
				if (isSecret) {
					document.body.classList.add('secret-room');
				} else {
					document.body.classList.remove('secret-room');
				}

				if (path === '/radio' || path === '/radio/') {
					document.body.classList.add('radio-room');
				} else {
					document.body.classList.remove('radio-room');
				}

				if (path === '/window' || path === '/window/') {
					document.body.classList.add('window-room');
				} else {
					document.body.classList.remove('window-room');
				}
			};

			updateSecretState();
			document.addEventListener('astro:page-load', updateSecretState);
		</script>
	</body>
</html>

