---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "okayimbored", 
  description = "A tiny corner of the internet for when you're bored."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="ImBored" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Preload the standard font we are simulating -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0a0a] text-white/90 font-sans min-h-[100dvh] flex flex-col overflow-x-hidden selection:bg-white/10 selection:text-white">
		<main class="w-full max-w-2xl mx-auto px-4 py-8 sm:px-6 sm:py-12 flex-1 flex flex-col items-center justify-center">
			<slot />
		</main>
	</body>
</html>
