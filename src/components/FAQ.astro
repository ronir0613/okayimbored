---
export interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="w-full mt-12 mb-16">
  <h2 class="text-3xl font-medium tracking-tight mb-8">Frequently Asked Questions</h2>
  
  <div class="space-y-4">
    {items.map((item, index) => (
      <details class="group border-b border-white/10 pb-4" name="faq-accordion">
        <summary class="flex justify-between items-center font-medium cursor-pointer list-none text-lg text-white/90 hover:text-white transition-colors">
          <span>{item.question}</span>
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-white/70 mt-4 leading-relaxed animate-in fade-in slide-in-from-top-2 duration-300">
          {item.answer}
        </p>
      </details>
    ))}
  </div>
</div>
