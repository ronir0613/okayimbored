---
import Layout from '../layouts/Layout.astro';
import CatDepartment from '../components/CatDepartment';
---

<Layout title="Cats" noindex={true} mainClass="w-full max-w-none p-0 flex-1 flex flex-col">
  <div class="relative w-full min-h-screen bg-[#050505]">
    <CatDepartment client:load />
    
    <div class="absolute top-8 left-8 sm:top-16 sm:left-16 z-50">
      <button 
        id="cat-return-btn" 
        class="text-[10px] text-white/20 hover:text-white/50 transition-colors uppercase tracking-[0.3em] font-mono cursor-pointer bg-transparent border-none"
      >
        return.
      </button>
    </div>
  </div>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client';
  
  const setupCatReturn = () => {
    const btn = document.getElementById('cat-return-btn');
    if (btn) {
      btn.addEventListener('click', () => {
        sessionStorage.setItem('okayimbored_returning_from_secret', 'true');
        navigate('/');
      });
    }
  };

  setupCatReturn();
  document.addEventListener('astro:page-load', setupCatReturn);
</script>
