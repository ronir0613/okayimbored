---
import Layout from '../layouts/Layout.astro';
import { PixelCat } from '../components/LivingCats/PixelCat';
---

<Layout title="Cats" noindex={true}>
  <div class="flex flex-col items-center justify-center min-h-[400px] space-y-8 select-none">
    <div class="w-16 h-16 opacity-75">
      <PixelCat state="sleeping" client:load />
    </div>
    
    <button 
      id="cat-return-btn" 
      class="text-xs text-white/20 hover:text-white/50 transition-colors uppercase tracking-widest font-mono cursor-pointer"
    >
      go back.
    </button>
  </div>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client';
  
  const setupCatReturn = () => {
    const btn = document.getElementById('cat-return-btn');
    if (btn) {
      btn.addEventListener('click', () => {
        sessionStorage.setItem('okayimbored_returning_from_secret', 'true');
        navigate('/');
      });
    }
  };

  setupCatReturn();
  document.addEventListener('astro:page-load', setupCatReturn);
</script>
