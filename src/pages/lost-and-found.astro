---
import Layout from '../layouts/Layout.astro';
import LostAndFoundComponent from '../components/LostAndFound';
---

<Layout title="Lost & Found" noindex={true}>
  <div class="flex flex-col items-center min-h-[100dvh] absolute inset-0 w-full overflow-hidden select-none bg-[#030303]">
    {/* Header */}
    <div class="z-20 mt-16 md:mt-24 text-center pointer-events-none px-4 w-full">
      <h1 class="text-2xl md:text-3xl font-mono text-white/60 tracking-[0.4em] uppercase font-light mb-4 ml-2">
        Lost & Found
      </h1>
      <p class="text-xs md:text-sm text-white/30 font-mono tracking-widest font-light">
        Things people accidentally left behind.
      </p>
    </div>

    {/* The Items */}
    <LostAndFoundComponent client:load />
  </div>
</Layout>
