---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Attic" noindex={true}>
  <div class="flex flex-col items-center justify-center min-h-[400px] space-y-12 select-none text-center">
    
    {/* Forgotten Index Card */}
    <div 
      id="attic-note"
      class="bg-[#121110] border border-white/5 p-6 sm:p-8 rounded max-w-sm w-full mx-4 shadow-xl transform rotate-[-1.5deg] hover:rotate-0 transition-transform duration-700"
    >
      <p id="attic-text" class="text-xs sm:text-sm font-mono text-white/50 leading-relaxed text-left">
        ...
      </p>
    </div>

    {/* Return Button */}
    <button 
      id="attic-back-btn"
      class="text-xs font-mono text-white/20 hover:text-white/50 transition-colors uppercase tracking-widest cursor-pointer"
    >
      back upstairs.
    </button>
  </div>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client';

  const notes = [
    "old versions of this website are probably up here somewhere.",
    "we lost a cat once.",
    "dust collects here. nobody has swept this page in a long time.",
    "we left the record playing down there.",
    "some things are better off misplaced."
  ];

  const initAttic = () => {
    const textEl = document.getElementById('attic-text');
    if (textEl) {
      const randNote = notes[Math.floor(Math.random() * notes.length)];
      textEl.textContent = randNote;
    }

    const btn = document.getElementById('attic-back-btn');
    if (btn) {
      btn.addEventListener('click', () => { sessionStorage.setItem('okayimbored_returning_from_secret', 'true'); navigate('/'); });
    }
  };

  initAttic();
  document.addEventListener('astro:page-load', initAttic);
</script>
