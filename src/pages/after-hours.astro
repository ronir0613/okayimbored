---
import Layout from '../layouts/Layout.astro';
---

<Layout title="After Hours" noindex={true}>
  <div class="flex flex-col items-center justify-center min-h-[400px] space-y-8 select-none text-center px-4">
    
    <div id="after-hours-open" class="hidden space-y-4">
      <p class="text-xl sm:text-2xl font-mono text-white/80">
        you're here after closing.
      </p>
      <p class="text-sm sm:text-base font-mono text-white/40 max-w-sm mx-auto leading-relaxed">
        But honestly, we don't have opening hours.
      </p>
    </div>

    <div id="after-hours-closed" class="hidden space-y-2">
      <p class="text-lg font-mono text-white/30">
        the door is locked.
      </p>
      <p class="text-xs font-mono text-white/10">
        (come back after midnight)
      </p>
    </div>

    <button 
      id="after-hours-btn"
      class="text-xs font-mono text-white/20 hover:text-white/50 transition-colors uppercase tracking-widest cursor-pointer mt-8"
    >
      continue.
    </button>
  </div>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client';

  const checkAfterHours = () => {
    const openEl = document.getElementById('after-hours-open');
    const closedEl = document.getElementById('after-hours-closed');
    const btnEl = document.getElementById('after-hours-btn');

    if (!openEl || !closedEl || !btnEl) return;

    const hour = new Date().getHours();
    
    // After hours is midnight (0) to 5:59 AM
    const isLateNight = hour >= 0 && hour < 6;

    if (isLateNight) {
      openEl.classList.remove('hidden');
      closedEl.classList.add('hidden');
      btnEl.textContent = 'continue.';
    } else {
      openEl.classList.add('hidden');
      closedEl.classList.remove('hidden');
      btnEl.textContent = 'go back.';
    }

    btnEl.addEventListener('click', () => { sessionStorage.setItem('okayimbored_returning_from_secret', 'true'); navigate('/'); });
  };

  checkAfterHours();
  document.addEventListener('astro:page-load', checkAfterHours);
</script>
