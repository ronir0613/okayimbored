---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Rooftop" noindex={true}>
  <div class="flex flex-col items-center justify-center min-h-[450px] select-none text-center relative w-full px-4 overflow-hidden">
    {/* Twinkling Starfield Canvas */}
    <canvas id="starfield-canvas" class="absolute inset-0 w-full h-full pointer-events-none opacity-50 z-0"></canvas>

    {/* Center text */}
    <p class="text-sm font-mono text-white/40 tracking-widest font-light z-10">
      good view.
    </p>

    {/* Return button */}
    <button 
      id="rooftop-back-btn"
      class="text-xs font-mono text-white/20 hover:text-white/50 transition-colors uppercase tracking-widest cursor-pointer mt-12 z-10"
    >
      back downstairs.
    </button>
  </div>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client';

  const initRooftop = () => {
    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animationId: number;
    let width = (canvas.width = canvas.offsetWidth);
    let height = (canvas.height = canvas.offsetHeight);

    // Reposition on resize
    const handleResize = () => {
      width = canvas.width = canvas.offsetWidth;
      height = canvas.height = canvas.offsetHeight;
    };
    window.addEventListener('resize', handleResize);

    // Generate stars
    const stars: { x: number; y: number; size: number; speed: number; phase: number }[] = [];
    const starCount = 80;

    for (let i = 0; i < starCount; i++) {
      stars.push({
        x: Math.random() * width,
        y: Math.random() * height,
        size: Math.random() * 1.5,
        speed: 0.01 + Math.random() * 0.02,
        phase: Math.random() * Math.PI * 2
      });
    }

    const draw = () => {
      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = 'white';

      stars.forEach(star => {
        star.phase += star.speed;
        const opacity = 0.2 + (Math.sin(star.phase) + 1) * 0.4;
        
        ctx.beginPath();
        ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
        ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
        ctx.fill();
      });

      animationId = requestAnimationFrame(draw);
    };

    draw();

    const btn = document.getElementById('rooftop-back-btn');
    if (btn) {
      btn.addEventListener('click', () => {
        window.removeEventListener('resize', handleResize);
        cancelAnimationFrame(animationId);
        sessionStorage.setItem('okayimbored_returning_from_secret', 'true');
        navigate('/');
      });
    }
  };

  initRooftop();
  document.addEventListener('astro:page-load', initRooftop);
</script>
