---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Not Found" noindex={true}>
  <div class="flex flex-col items-center justify-center min-h-[400px] space-y-8 select-none text-center px-4">
    <p class="text-lg sm:text-xl font-mono text-white/50 leading-relaxed max-w-sm">
      we've been looking for this page too.
    </p>

    <button 
      id="err-back-btn"
      class="text-xs font-mono text-white/20 hover:text-white/50 transition-colors uppercase tracking-widest cursor-pointer"
    >
      go back.
    </button>
  </div>
</Layout>

<script>
  import { navigate } from 'astro:transitions/client';

  const init404 = () => {
    const btn = document.getElementById('err-back-btn');
    if (btn) {
      btn.addEventListener('click', () => { sessionStorage.setItem('okayimbored_returning_from_secret', 'true'); navigate('/'); });
    }
  };

  init404();
  document.addEventListener('astro:page-load', init404);
</script>
