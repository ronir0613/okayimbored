---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Window" noindex={true}>
  <div class="flex flex-col items-center justify-center min-h-[450px] space-y-12 select-none text-center">
    
    {/* Window Frame Container */}
    <div class="relative w-[130px] h-[170px] border border-white/10 rounded bg-[#020203] overflow-hidden shadow-[inset_0_0_20px_rgba(0,0,0,0.9),0_0_15px_rgba(0,0,0,0.8)]">
      {/* Pane divider lines */}
      <div class="absolute top-0 bottom-0 left-1/2 w-[1px] bg-white/5 z-20"></div>
      <div class="absolute left-0 right-0 top-[35%] h-[1px] bg-white/5 z-20"></div>
      
      {/* Dynamic weather container */}
      <div id="window-sky" class="absolute inset-0 overflow-hidden z-10"></div>
    </div>

    {/* Text description */}
    <p class="text-sm font-mono text-white/40 tracking-wider font-light">
      someone else is awake.
    </p>

    {/* Back Button */}
    <button 
      id="window-back-btn"
      class="text-xs font-mono text-white/20 hover:text-white/50 transition-colors uppercase tracking-widest cursor-pointer"
    >
      go back.
    </button>
  </div>
</Layout>

<style is:global>
  /* Twinkling star */
  @keyframes twinkle {
    0%, 100% { opacity: 0.15; transform: scale(0.8); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }

  /* Rain falling */
  @keyframes rainfall {
    0% { transform: translateY(-20px) translateX(0); }
    100% { transform: translateY(190px) translateX(5px); }
  }

  /* Cloud drifting */
  @keyframes drift {
    0% { transform: translateX(-80px); }
    100% { transform: translateX(150px); }
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';

  const initWindow = () => {
    const sky = document.getElementById('window-sky');
    if (!sky) return;
    
    // Clear previous sky elements
    sky.innerHTML = '';

    const types = ['rain', 'stars', 'clouds'];
    const weather = types[Math.floor(Math.random() * types.length)];

    if (weather === 'stars') {
      // Twinkling stars
      for (let i = 0; i < 15; i++) {
        const star = document.createElement('div');
        star.className = 'absolute bg-white/70 rounded-full';
        
        const size = Math.random() > 0.6 ? 2 : 1;
        star.style.width = `${size}px`;
        star.style.height = `${size}px`;
        star.style.left = `${Math.random() * 100}%`;
        star.style.top = `${Math.random() * 100}%`;
        
        star.style.animation = `twinkle ${2 + Math.random() * 3}s ease-in-out infinite`;
        star.style.animationDelay = `${Math.random() * 2}s`;
        
        sky.appendChild(star);
      }
    } else if (weather === 'rain') {
      // Rain drops
      for (let i = 0; i < 20; i++) {
        const drop = document.createElement('div');
        drop.className = 'absolute bg-white/10 w-[1px] h-[8px]';
        drop.style.left = `${Math.random() * 100}%`;
        drop.style.top = `${Math.random() * -30}px`;
        
        drop.style.animation = `rainfall ${0.8 + Math.random() * 0.6}s linear infinite`;
        drop.style.animationDelay = `${Math.random() * 1}s`;
        
        sky.appendChild(drop);
      }
    } else {
      // Drifting clouds
      for (let i = 0; i < 3; i++) {
        const cloud = document.createElement('div');
        cloud.className = 'absolute bg-white/[0.015] rounded-full blur-[8px]';
        
        const w = 40 + Math.random() * 40;
        const h = w * 0.6;
        cloud.style.width = `${w}px`;
        cloud.style.height = `${h}px`;
        cloud.style.top = `${Math.random() * 70}%`;
        cloud.style.left = `0px`;
        
        cloud.style.animation = `drift ${20 + Math.random() * 20}s linear infinite`;
        cloud.style.animationDelay = `-${Math.random() * 15}s`;
        
        sky.appendChild(cloud);
      }
    }

    const btn = document.getElementById('window-back-btn');
    if (btn) {
      btn.addEventListener('click', () => { sessionStorage.setItem('okayimbored_returning_from_secret', 'true'); navigate('/'); });
    }
  };

  initWindow();
  document.addEventListener('astro:page-load', initWindow);
</script>
